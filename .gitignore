# ============================================================
# SENTINEL - .gitignore
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# ------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------
.venv/
.venv-paddle/
venv/
env/

# ------------------------------------------------------------
# IDE
# ------------------------------------------------------------
.vscode/
.idea/

# ------------------------------------------------------------
# Operating System
# ------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
# Runtime Output
# ------------------------------------------------------------
output/
output/debug/

# ------------------------------------------------------------
# Benchmark Results
# ------------------------------------------------------------
benchmarks/*.xlsx
benchmarks/*.json
benchmarks/*.log

# ------------------------------------------------------------
# OCR Model Cache
# ------------------------------------------------------------
.paddlex/
.paddleocr/

*.pdmodel
*.pdiparams
*.pdiparams.info
*.nb

# ------------------------------------------------------------
# Databases
# ------------------------------------------------------------
database/*.db
database/*.sqlite
database/*.sqlite3

# ------------------------------------------------------------
# Temporary / Cache
# ------------------------------------------------------------
.cache/
pytest_cache/
.pytest_cache/
.mypy_cache/

# ------------------------------------------------------------
# Build / Distribution
# ------------------------------------------------------------
build/
dist/
*.egg-info/

# ------------------------------------------------------------
# Release Packages
# ------------------------------------------------------------
*.zip

# ------------------------------------------------------------
# Local Validation Assets
# (werden lokal verwendet und NICHT versioniert)
# ------------------------------------------------------------
input/
screenshots/

# Ground Truth Reports (werden automatisch erzeugt)
ground_truth/reports/

# ------------------------------------------------------------
# Office Temp Files
# ------------------------------------------------------------
~$*.xlsx
~$*.xlsm